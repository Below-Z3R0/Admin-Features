# Supabase — copia este archivo a `.env.local` y rellena con tus credenciales.
NEXT_PUBLIC_SUPABASE_URL="https://<tu-proyecto>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<tu-anon-key>"

# URL del sitio. En dev: http://localhost:3000. En prod: tu dominio real.
# Se usa para construir el `redirectTo` de OAuth (login con Google).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
